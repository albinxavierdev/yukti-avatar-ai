# Groq LLM (required for chat)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Auth — set AUTH_DISABLED=1 to skip login during local dev
AUTH_DISABLED=0
SECRET_KEY=generate-a-long-random-string
BASE_URL=http://127.0.0.1:8765

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:8765/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional paths
DATABASE_PATH=data/yukti.db
MEM0_DIR=data/mem0
CHAT_HISTORY_LIMIT=20

CHAT_HISTORY_LIMIT=10

# Remote TTS via bizfyvoice (https://voice.bizfylabs.com or local :8000)
BIZFY_VOICE_URL=http://127.0.0.1:8000
BIZFY_VOICE_API_KEY=bizfy-voice-2026
BIZFY_VOICE_SPEED=1.08
TTS_MIN_CHUNK_CHARS=1
TTS_MAX_CHUNK_CHARS=40

# Startup preload
PRELOAD_TTS_WARMUP=1
PRELOAD_AVATARS=1
PRELOAD_VENDOR_ASSETS=1
